# Copy this file to .env and fill real secrets locally.
# Do not commit .env with real tokens.

# Required secrets
BOT_TOKEN=replace_with_telegram_bot_token
GEMINI_API_KEY=replace_with_gemini_api_key
ADMIN_IDS=123456789
# Shows only a minimal safe Telegram command menu for regular users.
# Admins still get admin-scoped commands.
HIDE_USER_COMMANDS=1
# One-time migration helper for old per-chat Telegram command scopes.
# Keep disabled for normal startups; enable once only if stale commands persist.
CLEAR_KNOWN_USER_COMMANDS_ON_STARTUP=0

# Database / runtime
DB_PATH=bot_database.sqlite
REDIS_URL=redis://localhost:6379/0

# Runtime API / webhooks
APP_VERSION=0.1.0
# polling keeps the current bot behavior. webhook serves Telegram updates over HTTP.
BOT_RUNTIME_MODE=polling
# Enables /health, /ready, /metrics, /version next to polling.
API_ENABLED=0
API_HOST=127.0.0.1
API_PORT=8080
# Docker Compose host binding for the API port.
API_BIND_ADDRESS=127.0.0.1
API_HOST_PORT=8081
# Optional Bearer token for /metrics and /admin/stats.
API_AUTH_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# AI parsing
AI_PROVIDER_CHAIN=gemini
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_TEXT_MODEL_CHAIN=gemini-3.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-2.5-flash,gemini-2.5-pro,gemini-2.5-flash-lite
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_NUM_CTX=16384
OLLAMA_KEEP_ALIVE=10m

# Gemini stability
GEMINI_REQUEST_TIMEOUT_SECONDS=45
GEMINI_RETRY_ATTEMPTS=2
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0
GEMINI_RETRY_MAX_DELAY_SECONDS=6.0

# Optional manual cost estimates for admin statistics.
# Keep 0.0 if you do not want estimated costs in the bot UI.
GEMINI_ESTIMATED_INPUT_COST_PER_1K_CHARS_USD=0.0
GEMINI_ESTIMATED_OUTPUT_COST_PER_1K_CHARS_USD=0.0
TTS_ESTIMATED_COST_PER_1K_CHARS_USD=0.0

# Photos / Gemini OCR
GEMINI_OCR_MODEL=gemini-3.1-flash-lite
GEMINI_OCR_MODEL_CHAIN=gemini-3.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-2.5-flash,gemini-2.5-pro,gemini-2.5-flash-lite
OCR_MIN_TEXT_LENGTH=12

# TTS providers
TTS_PROVIDER=edge
TTS_PROVIDER_CHAIN=edge
DEFAULT_VOICE=uk-UA-PolinaNeural
DEFAULT_RATE=+0%

# Gemini TTS
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_MODEL_CHAIN=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
GEMINI_TTS_FEMALE_VOICE=Kore
GEMINI_TTS_MALE_VOICE=Charon
GEMINI_TTS_STYLE_PROMPT=Detect the language of the input text automatically and read it clearly and naturally in the same language. Keep a calm, friendly pace and a consistent neutral newsroom tone. Treat every chunk as part of one continuous article.
GEMINI_TTS_REQUEST_TIMEOUT_SECONDS=120
GEMINI_TTS_CHUNK_MAX_LENGTH=1600

# Piper
PIPER_EXECUTABLE=piper
PIPER_MODELS_DIR=data/piper
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=
PIPER_LANGUAGE_MODELS_JSON=
PIPER_SPEAKER=
PIPER_LENGTH_SCALE=1.0
PIPER_TIMEOUT_SECONDS=60

# Rate limit
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_MAX_EVENTS=8
RATE_LIMIT_PERIOD_SECONDS=10
RATE_LIMIT_WARNING_COOLDOWN_SECONDS=10

# Reading sessions and cleanup
READING_SESSION_TTL_SECONDS=2700
READING_SESSION_BACKEND=redis
READING_AUDIO_QUEUE_BACKEND=redis
READING_AUDIO_QUEUE_REDIS_KEY=reading:audio:queue
READING_AUDIO_QUEUE_MAX_SIZE=20
EXPORT_AUDIO_MAX_SIZE_MB=48
EXPORT_AUDIO_SMOOTH_MERGE_ENABLED=1
EXPORT_AUDIO_CROSSFADE_MS=120
DOCUMENT_HISTORY_RETENTION_DAYS=90
SERVICE_METRICS_RETENTION_DAYS=30
MAINTENANCE_CLEANUP_INTERVAL_SECONDS=86400

# Audio cache
AUDIO_CACHE_ENABLED=1
AUDIO_CACHE_DIR=data/audio_cache
AUDIO_CACHE_MAX_SIZE_MB=1024
AUDIO_CACHE_MAX_AGE_DAYS=30
AUDIO_CACHE_CLEANUP_INTERVAL_SECONDS=3600

# Daily limits for regular users
FREE_DAILY_TEXT_MESSAGE_LIMIT=100
FREE_DAILY_FILE_LIMIT=10
FREE_DAILY_OCR_LIMIT=10
FREE_DAILY_LINK_LIMIT=20
FREE_DAILY_SUMMARY_LIMIT=5

# Logging
LOG_LEVEL=INFO
# Use text for local reading. Use json when logs are collected by Loki/ELK/Cloud Logging.
LOG_FORMAT=text
LOG_SERVICE_NAME=audio-assistant

# External metrics / alerts
METRICS_REDIS_STREAM_ENABLED=0
METRICS_REDIS_STREAM_KEY=metrics:service
METRICS_REDIS_STREAM_MAXLEN=10000
METRICS_ALERT_WEBHOOK_URL=
METRICS_ALERT_ON_FAILURE=1
METRICS_ALERT_TIMEOUT_SECONDS=5
